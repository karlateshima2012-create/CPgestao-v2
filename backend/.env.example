APP_NAME=CPGestao
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cpgestao.creativeprintjp.com

LOG_CHANNEL=daily
LOG_LEVEL=warning

# Database - Hostinger Shared MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u123456789_cpgestao
DB_USERNAME=u123456789_admin
DB_PASSWORD=SuaSenhaForteAqui

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# CORS Allowed Origins
# Como front e back estão no mesmo domínio, CORS é menos crítico,
# mas mantemos por segurança.
CORS_ALLOWED_ORIGINS=https://cpgestao.creativeprintjp.com
